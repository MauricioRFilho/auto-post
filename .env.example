# ------------------------------------------------------------------------------
# 🚀 Cadence Auto-Post - Configuração do Ambiente (.env)
# ------------------------------------------------------------------------------

# 🏗️ Infraestrutura (Docker trata isso automaticamente no setup padrão)
PORT=8080
DATABASE_URL=postgresql://autopost:autopost_dev_pass@postgres:5432/affiliates
REDIS_URL=redis://redis:6379/0
JWT_SECRET=mudar_em_producao_12345
NODE_ENV=development

# ✈️ Telegram (Obrigatório para postagem gratuita)
# Crie seu bot no @BotFather para obter o TOKEN
TELEGRAM_BOT_TOKEN=seu_token_aqui
# Consiga seu Chat ID enviando uma mensagem para o bot e acessando:
# https://api.telegram.org/bot<SEU_TOKEN>/getUpdates
TELEGRAM_CHAT_ID=seu_chat_id_aqui

# 🖼️ Dashboard
NEXT_PUBLIC_API_URL=http://localhost:8080

# ------------------------------------------------------------------------------
# 🛠️ Como usar:
# 1. Copie este arquivo para um novo chamado .env
# 2. Preencha TELEGRAM_BOT_TOKEN e TELEGRAM_CHAT_ID
# 3. Rode: docker compose up --build
# ------------------------------------------------------------------------------
